<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>SATOSHIMPORT</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Google Fonts -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
    }

    body {
      background: #ffffff;
      color: #111;
    }

    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 20px 40px;
      background: #000;
      color: #fff;
    }

    header h1 {
      font-weight: 600;
      letter-spacing: 2px;
    }

    nav a {
      color: #fff;
      margin-left: 20px;
      text-decoration: none;
      transition: 0.3s;
    }

    nav a:hover {
      color: gold;
    }

    .hero {
      height: 90vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      background: linear-gradient(to right, #000, #333);
      color: #fff;
      text-align: center;
      padding: 20px;
    }

    .hero h2 {
      font-size: 3rem;
      margin-bottom: 20px;
    }

    .hero button {
      padding: 15px 30px;
      border: none;
      background: gold;
      cursor: pointer;
      font-weight: bold;
      transition: 0.3s;
    }

    .hero button:hover {
      background: #d4af37;
    }

    .section {
      padding: 60px 40px;
      text-align: center;
    }

    .productos {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
      margin-top: 40px;
    }

    .producto {
      border: 1px solid #ddd;
      padding: 20px;
      transition: 0.3s;
    }

    .producto:hover {
      transform: translateY(-5px);
      box-shadow: 0 5px 20px rgba(0,0,0,0.1);
    }

    .producto img {
      width: 100%;
      height: 200px;
      object-fit: cover;
    }

    .producto h3 {
      margin: 15px 0;
    }

    .producto button {
      padding: 10px 20px;
      background: black;
      color: white;
      border: none;
      cursor: pointer;
    }

    .features {
      display: flex;
      justify-content: space-around;
      flex-wrap: wrap;
      margin-top: 40px;
    }

    .feature {
      width: 200px;
      margin: 20px;
    }

    footer {
      background: #000;
      color: #fff;
      text-align: center;
      padding: 30px;
      margin-top: 40px;
    }
  </style>
</head>

<body>

<header>
  <h1>SATOSHIMPORT</h1>
  <nav>
    <a href="#">Inicio</a>
    <a href="#productos">Productos</a>
    <a href="#nosotros">Nosotros</a>
    <a href="#contacto">Contacto</a>
  </nav>
</header>

<section class="hero">
  <h2>Importamos lo mejor del mundo para ti</h2>
  <p>Calidad, tecnología y precios increíbles</p>
  <button onclick="scrollToProductos()">Ver productos</button>
</section>

<section class="section" id="productos">
  <h2>Productos destacados</h2>

  <div class="productos">
    <div class="producto">
      <img src="https://via.placeholder.com/300">
      <h3>Smartwatch Pro</h3>
      <p>$49.99</p>
      <button>Comprar</button>
    </div>

    <div class="producto">
      <img src="https://via.placeholder.com/300">
      <h3>Audífonos Bluetooth</h3>
      <p>$29.99</p>
      <button>Comprar</button>
    </div>

    <div class="producto">
      <img src="https://via.placeholder.com/300">
      <h3>Luz LED RGB</h3>
      <p>$19.99</p>
      <button>Comprar</button>
    </div>
  </div>
</section>

<section class="section" id="nosotros">
  <h2>¿Por qué elegirnos?</h2>

  <div class="features">
    <div class="feature">
      <h3>🌍 Importación directa</h3>
    </div>

    <div class="feature">
      <h3>💰 Mejores precios</h3>
    </div>

    <div class="feature">
      <h3>🚚 Envíos rápidos</h3>
    </div>

    <div class="feature">
      <h3>🔒 Compra segura</h3>
    </div>
  </div>
</section>

<section class="section" id="contacto">
  <h2>Contacto</h2>
  <p>Email: contacto@satoshimport.com</p>
  <p>WhatsApp: +00 000 000 000</p>
</section>

<footer>
  <p>© 2026 SATOSHIMPORT - Todos los derechos reservados</p>
</footer>

<script>
  function scrollToProductos() {
    document.getElementById("productos").scrollIntoView({ behavior: "smooth" });
  }
</script>
</body>
</html>
